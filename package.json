{
  "name": "greenpage",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate:node-index": "node scripts/generate_node_index.mjs",
    "generate:trip-dots": "node scripts/generate_trip_dots.mjs",
    "predev": "npm run generate:node-index && npm run generate:trip-dots",
    "prebuild": "npm run generate:node-index && npm run generate:trip-dots",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "postbuild": "node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@protomaps/basemaps": "^5.7.2",
    "@turf/bbox": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/center-of-mass": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "@turf/great-circle": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "@xyflow/react": "^12.8.6",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "lucide-react": "^0.546.0",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "prismjs": "^1.30.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.2",
    "terra-draw": "^1.32.0",
    "terra-draw-maplibre-gl-adapter": "^1.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "globals": "^16.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7"
  }
}
